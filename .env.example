POSTGRES_DB=cloudcad
POSTGRES_USER=cloudcad
POSTGRES_PASSWORD=replace-with-a-strong-database-password

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MINUTES=1440

# Use your final server URL here, for example:
# CORS_ALLOWED_ORIGINS=http://your-server-ip
# CORS_ALLOWED_ORIGINS=https://cad.example.com
CORS_ALLOWED_ORIGINS=http://localhost

# Keep these empty when frontend and backend are served by the same Nginx container.
VITE_API_BASE_URL=
VITE_WS_URL=

# Change to 8081:80 or another host port if port 80 is already occupied.
HTTP_PORT=80

# Optional JVM settings for the backend container.
JAVA_OPTS=-Xms256m -Xmx768m
